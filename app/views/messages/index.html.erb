<% content_for :title, "Messages" %>

<%= section_container do %>
  <%# Page Header %>
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-4xl font-black tracking-tight text-zinc-900">💬 Messages</h1>
        <p class="text-zinc-700 font-medium text-lg mt-2">Your mentorship conversations and updates</p>
      </div>
      <%= button_primary "✨ New message", new_message_path %>
    </div>
  </div>

  <%# Messages Grid %>
  <div id="messages" class="space-y-6">
    <% if @messages.any? %>
      <% @messages.each do |message| %>
        <div class="rounded-xl border-2 border-zinc-700 bg-zinc-800 p-6 shadow-xl">
          <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4">
            <div class="flex-1">
              <%= render message %>
            </div>
            <div class="flex flex-col sm:flex-row gap-2 lg:flex-col lg:w-auto">
              <%= button_secondary "👀 View", message, class: "text-sm" %>
              <%= button_secondary "✏️ Edit", edit_message_path(message), class: "text-sm" %>
              <%= button_to "🗑️ Delete", message, method: :delete, 
                    class: "inline-flex items-center gap-2 rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-700 transition-colors shadow-lg", 
                    data: { turbo_confirm: "Are you sure you want to delete this message?" } %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <%= empty_state "No messages yet. Start a conversation!", "💬" %>
    <% end %>
  </div>
<% end %>
