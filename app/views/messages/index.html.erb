<% content_for :title, "Messages" %>

<%= section_container do %>
  <%# Page Header %>
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-4xl font-black tracking-tight text-zinc-100"><i class="fa-regular fa-comments mr-2"></i> Conversations</h1>
        <p class="text-zinc-400 font-medium text-lg mt-2">Your mentorship chats</p>
      </div>
    </div>
  </div>

  <%# Conversations List %>
  <div id="conversations" class="space-y-3">
    <% if @conversations.any? %>
      <% @conversations.each do |conversation| %>
        <% other_user = conversation.mentee_id == current_user.id ? conversation.mentor : conversation.mentee %>
        <% last_message = conversation.messages.order(created_at: :desc).first %>
        <% unread_count = conversation.messages.where.not(user_id: current_user.id).where(read_at: nil).count %>

        <%= link_to mentorship_request_path(conversation), class: "block" do %>
          <div class="rounded-xl border border-zinc-700 bg-zinc-800/50 hover:bg-zinc-800 hover:border-zinc-600 p-4 transition-all smooth-transition hover:shadow-lg hover:shadow-rose-500/10">
            <div class="flex items-center gap-4">
              <%# Avatar %>
              <div class="shrink-0 relative">
                <div class="h-14 w-14 rounded-full text-white grid place-items-center text-lg font-bold <%= avatar_color_class(other_user) %> shadow-lg">
                  <%= user_initials(other_user) %>
                </div>
                <% if unread_count > 0 %>
                  <div class="absolute -top-1 -right-1 bg-rose-500 text-white text-xs font-bold rounded-full h-6 w-6 flex items-center justify-center shadow-lg">
                    <%= unread_count %>
                  </div>
                <% end %>
              </div>

              <%# Conversation Info %>
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-1">
                  <h3 class="text-lg font-bold text-zinc-100 truncate">
                    <%= display_name(other_user) %>
                  </h3>
                  <% if last_message %>
                    <span class="text-xs text-zinc-500 ml-2 shrink-0">
                      <%= time_ago_in_words(last_message.created_at) %> ago
                    </span>
                  <% end %>
                </div>

                <p class="text-sm text-zinc-400 mb-2 truncate">
                  <%= conversation.topic %>
                </p>

                <% if last_message %>
                  <p class="text-sm <%= unread_count > 0 ? 'text-zinc-200 font-semibold' : 'text-zinc-500' %> truncate">
                    <% if last_message.user_id == current_user.id %>
                      <span class="text-zinc-600">You: </span>
                    <% end %>
                    <%= last_message.body %>
                  </p>
                <% else %>
                  <p class="text-sm text-zinc-600 italic">No messages yet</p>
                <% end %>
              </div>

              <%# Arrow %>
              <div class="shrink-0">
                <i class="fa-solid fa-chevron-right text-zinc-600"></i>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="text-center py-16">
        <i class="fa-regular fa-comments text-6xl text-zinc-700 mb-4"></i>
        <h3 class="text-xl font-bold text-zinc-400 mb-2">No conversations yet</h3>
        <p class="text-zinc-500 mb-6">Start by requesting mentorship or accepting a request</p>
        <%= link_to raw('<i class="fa-solid fa-rocket mr-2"></i> Browse Mentors'), profiles_path, class: "inline-flex items-center gap-2 rounded-xl bg-rose-600 px-6 py-3 text-white font-bold hover:bg-rose-700 transition-colors shadow-lg" %>
      </div>
    <% end %>
  </div>
<% end %>
