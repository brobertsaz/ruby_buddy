<% mine = defined?(current_user) && message.user_id == current_user&.id %>
<div class="w-full py-1 flex <%= mine ? 'justify-end' : 'justify-start' %>">
  <div class="flex items-end gap-2 max-w-[80%] <%= mine ? 'flex-row-reverse' : 'flex-row' %>">
    <!-- Avatar with online status -->
    <div class="shrink-0 relative">
      <div class="h-8 w-8 rounded-full text-white grid place-items-center text-xs font-semibold <%= avatar_color_class(message.user) %> smooth-transition scale-hover">
        <%= user_initials(message.user) %>
      </div>
      <!-- Online status indicator -->
      <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-green-400 rounded-full border-2 border-zinc-900"></div>
    </div>

    <!-- Message Bubble with enhanced dark theme styling -->
    <div id="<%= dom_id message %>"
         class="message-bubble rounded-2xl px-4 py-3 text-sm shadow-lg smooth-transition
                <%= mine ? 'message-bubble-sent bg-gradient-to-br from-blue-600 to-blue-700 text-white' : 'message-bubble-received bg-gradient-to-br from-zinc-700 to-zinc-800 ring-1 ring-zinc-600 text-zinc-100' %>">

      <!-- Message Header -->
      <div class="flex items-center justify-between mb-1">
        <div class="opacity-80 text-[11px] font-medium <%= mine ? 'text-blue-100' : 'text-zinc-300' %>">
          <%= display_name(message.user) %>
        </div>
        <div class="message-timestamp opacity-0 text-[10px] <%= mine ? 'text-blue-200' : 'text-zinc-400' %>">
          <%= message.created_at.strftime("%H:%M") %>
        </div>
      </div>

      <!-- Message Content -->
      <div class="whitespace-pre-wrap leading-relaxed mb-2 <%= mine ? 'text-white' : 'text-zinc-100' %>">
        <%= message.body %>
      </div>

      <!-- Message Status Indicator -->
      <div class="flex items-center justify-between">
        <div class="text-[10px] opacity-60 <%= mine ? 'text-blue-200' : 'text-zinc-400' %>">
          <%= time_ago_in_words(message.created_at) %> ago
        </div>

        <div data-message-status-target="status" class="message-status">
          <% if mine %>
            <!-- Show status for sent messages -->
            <% if message.read? %>
              <div class="flex items-center space-x-1">
                <i class="fa-solid fa-check-double text-green-300 text-[10px]"></i>
                <span class="text-[9px] text-green-300 font-medium">Read</span>
              </div>
            <% elsif message.sent_at.present? %>
              <div class="flex items-center space-x-1">
                <i class="fa-solid fa-check text-blue-300 text-[10px]"></i>
                <span class="text-[9px] text-blue-300 font-medium">Sent</span>
              </div>
            <% else %>
              <div class="flex items-center space-x-1">
                <i class="fa-solid fa-clock text-blue-300 text-[10px]"></i>
                <span class="text-[9px] text-blue-300 font-medium">Sending...</span>
              </div>
            <% end %>
          <% else %>
            <!-- Placeholder for received message status updates -->
          <% end %>
        </div>
      </div>

      <!-- Message reactions placeholder (for future enhancement) -->
      <div class="message-reactions mt-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
        <!-- Future: Add reaction buttons here -->
      </div>
    </div>
  </div>
</div>
