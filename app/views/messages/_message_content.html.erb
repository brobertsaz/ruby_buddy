<%# This partial renders the message content without the wrapper %>
<%# The wrapper determines if it's "mine" or "theirs" via JavaScript %>

<div class="message-inner w-full py-1" data-user-id="<%= message.user_id %>">
  <div class="flex items-end gap-2 max-w-[80%]">
    <!-- Avatar with online status -->
    <div class="shrink-0 relative avatar-container">
      <div class="h-8 w-8 rounded-full text-white grid place-items-center text-xs font-semibold <%= avatar_color_class(message.user) %> smooth-transition scale-hover">
        <%= user_initials(message.user) %>
      </div>
      <!-- Online status indicator -->
      <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-green-400 rounded-full border-2 border-zinc-900"></div>
    </div>

    <!-- Message Bubble -->
    <div id="<%= dom_id message %>" class="bubble rounded-2xl px-4 py-3 text-sm shadow-lg smooth-transition">
      <!-- Message Header -->
      <div class="flex items-center justify-between mb-1">
        <div class="opacity-80 text-[11px] font-medium sender-name">
          <%= display_name(message.user) %>
        </div>
        <div class="message-timestamp opacity-0 text-[10px] timestamp">
          <%= message.created_at.strftime("%H:%M") %>
        </div>
      </div>

      <!-- Message Content -->
      <div class="whitespace-pre-wrap leading-relaxed mb-2 message-text">
        <%= message.body %>
      </div>

      <!-- Message Status Indicator -->
      <div class="flex items-center justify-between">
        <div class="text-[10px] opacity-60 time-ago">
          <%= time_ago_in_words(message.created_at) %> ago
        </div>

        <div data-message-status-target="status" class="message-status status-indicator">
          <!-- Status will be added by JavaScript for sent messages -->
        </div>
      </div>
    </div>
  </div>
</div>

