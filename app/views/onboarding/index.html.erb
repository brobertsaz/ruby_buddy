<% content_for :title, "Welcome to Ruby Buddy!" %>

<div class="max-w-4xl mx-auto text-center">
  <!-- Hero Section -->
  <div class="mb-12">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-rose-500 to-red-600 rounded-full mb-6">
      <span class="text-3xl">🎉</span>
    </div>

    <h1 class="text-5xl font-black text-gray-900 mb-4">
      Welcome to <span class="text-rose-600">Ruby Buddy</span>!
    </h1>

    <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
      You're now part of a community connecting Ruby developers!
      Let's get you set up so you can start mentoring or finding mentors right away.
    </p>
  </div>

  <!-- Quick Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 rounded-xl p-6">
      <div class="text-2xl mb-2">🚀</div>
      <div class="text-2xl font-bold text-blue-900">Free</div>
      <div class="text-sm text-blue-700">Always & Forever</div>
    </div>

    <div class="bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-xl p-6">
      <div class="text-2xl mb-2">🤝</div>
      <div class="text-2xl font-bold text-green-900">Community</div>
      <div class="text-sm text-green-700">Friendly & Welcoming</div>
    </div>

    <div class="bg-gradient-to-br from-purple-50 to-pink-50 border border-purple-200 rounded-xl p-6">
      <div class="text-2xl mb-2">💎</div>
      <div class="text-2xl font-bold text-purple-900">Ruby</div>
      <div class="text-sm text-purple-700">Focus & Expertise</div>
    </div>
  </div>

  <!-- Call to Action -->
  <div class="bg-white rounded-2xl border-2 border-gray-100 shadow-lg p-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">
      Let's get started!
    </h2>

    <p class="text-gray-600 mb-8">
      First, tell us how you'd like to participate in our community.
    </p>

    <%= link_to onboarding_choose_role_path,
        class: "inline-flex items-center gap-2 bg-gradient-to-r from-rose-500 to-red-600 text-white font-bold text-lg px-8 py-4 rounded-xl hover:from-rose-600 hover:to-red-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl" do %>
      <span>Choose Your Path</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    <% end %>
  </div>

  <!-- Progress Indicator -->
  <div class="mt-8">
    <div class="flex items-center justify-center space-x-2">
      <div class="w-8 h-8 bg-rose-500 text-white rounded-full flex items-center justify-center text-sm font-bold">1</div>
      <div class="w-16 h-1 bg-gray-200 rounded"></div>
      <div class="w-8 h-8 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center text-sm font-bold">2</div>
      <div class="w-16 h-1 bg-gray-200 rounded"></div>
      <div class="w-8 h-8 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center text-sm font-bold">3</div>
    </div>
    <div class="flex justify-center mt-2">
      <span class="text-sm text-gray-500">Welcome → <strong class="text-rose-600">Choose Role</strong> → Complete</span>
    </div>
  </div>
</div>