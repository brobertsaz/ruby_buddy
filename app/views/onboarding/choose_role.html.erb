<% content_for :title, "Choose Your Role" %>

<div class="max-w-5xl mx-auto">
  <!-- Header -->
  <div class="text-center mb-12">
    <h1 class="text-4xl font-black text-zinc-100 mb-4">
      How would you like to participate?
    </h1>
    <p class="text-xl text-zinc-400 max-w-2xl mx-auto">
      Choose the path that best describes your journey with Ruby development.
      Don't worry—you can always change this later!
    </p>
  </div>

  <!-- Role Selection Cards -->
  <%= form_with scope: :user, url: onboarding_set_role_path, method: :post, local: true, class: "space-y-6" do |form| %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- Mentee Option -->
      <label class="role-card group cursor-pointer">
        <%= form.radio_button :role, "mentee", class: "sr-only role-radio peer" %>
        <div class="bg-zinc-900 border-2 border-zinc-700 rounded-2xl p-8 transition-all duration-200 group-hover:border-blue-400 group-hover:shadow-lg group-hover:scale-105 h-full flex flex-col peer-checked:ring-2 peer-checked:ring-blue-500/50">

          <!-- Icon -->
          <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-blue-500/10 to-indigo-500/10 rounded-full mb-4">
              <span class="text-3xl"><i class="fa-solid fa-bullseye"></i></span>
            </div>
            <h3 class="text-2xl font-bold text-zinc-100">I'm Learning</h3>
            <p class="text-blue-400 font-medium">Looking for a Mentor</p>
          </div>

          <!-- Description -->
          <div class="flex-1">
            <ul class="space-y-3 text-zinc-300">
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>New to Ruby or programming</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Want guidance from experienced developers</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Looking for career advice & code reviews</span>
              </li>
            </ul>
          </div>

          <!-- What happens next -->
          <div class="mt-6 pt-6 border-t border-zinc-800">
            <p class="text-sm text-zinc-400 font-medium">Next: Create your mentorship request</p>
          </div>
        </div>
      </label>

      <!-- Mentor Option -->
      <label class="role-card group cursor-pointer">
        <%= form.radio_button :role, "mentor", class: "sr-only role-radio peer" %>
        <div class="bg-zinc-900 border-2 border-zinc-700 rounded-2xl p-8 transition-all duration-200 group-hover:border-green-400 group-hover:shadow-lg group-hover:scale-105 h-full flex flex-col peer-checked:ring-2 peer-checked:ring-green-500/50">

          <!-- Icon -->
          <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-green-500/10 to-emerald-500/10 rounded-full mb-4">
              <span class="text-3xl"><i class="fa-solid fa-star"></i></span>
            </div>
            <h3 class="text-2xl font-bold text-zinc-100">I Can Help</h3>
            <p class="text-green-400 font-medium">Available Mentor</p>
          </div>

          <!-- Description -->
          <div class="flex-1">
            <ul class="space-y-3 text-zinc-300">
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>1+ years of Ruby experience</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Want to share knowledge & give back</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Enjoy helping others grow</span>
              </li>
            </ul>
          </div>

          <!-- What happens next -->
          <div class="mt-6 pt-6 border-t border-zinc-800">
            <p class="text-sm text-zinc-400 font-medium">Next: Set up your mentor profile</p>
          </div>
        </div>
      </label>

      <!-- Both Option -->
      <label class="role-card group cursor-pointer">
        <%= form.radio_button :role, "both", class: "sr-only role-radio peer" %>
        <div class="bg-zinc-900 border-2 border-zinc-700 rounded-2xl p-8 transition-all duration-200 group-hover:border-purple-400 group-hover:shadow-lg group-hover:scale-105 h-full flex flex-col peer-checked:ring-2 peer-checked:ring-purple-500/50">

          <!-- Icon -->
          <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-full mb-4">
              <span class="text-3xl"><i class="fa-solid fa-handshake"></i></span>
            </div>
            <h3 class="text-2xl font-bold text-zinc-100">Both!</h3>
            <p class="text-purple-400 font-medium">Mentor & Mentee</p>
          </div>

          <!-- Description -->
          <div class="flex-1">
            <ul class="space-y-3 text-zinc-300">
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-purple-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Can help newcomers in some areas</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-purple-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Want to learn advanced topics too</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-purple-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Love the community aspect</span>
              </li>
            </ul>
          </div>

          <!-- What happens next -->
          <div class="mt-6 pt-6 border-t border-zinc-800">
            <p class="text-sm text-zinc-400 font-medium">Next: Complete setup & explore options</p>
          </div>
        </div>
      </label>
    </div>

    <!-- Submit Button -->
    <div class="text-center mt-12">
      <%= form.submit "Continue",
          class: "bg-gradient-to-r from-rose-500 to-red-600 text-white font-bold text-lg px-12 py-4 rounded-xl hover:from-rose-600 hover:to-red-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed",
          id: "continue-btn",
          disabled: true %>
    </div>
  <% end %>

  <!-- Progress Indicator -->
  <div class="mt-8">
    <div class="flex items-center justify-center space-x-2">
      <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold">✓</div>
      <div class="w-16 h-1 bg-green-500 rounded"></div>
      <div class="w-8 h-8 bg-rose-500 text-white rounded-full flex items-center justify-center text-sm font-bold">2</div>
      <div class="w-16 h-1 bg-gray-200 rounded"></div>
      <div class="w-8 h-8 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center text-sm font-bold">3</div>
    </div>
    <div class="flex justify-center mt-2">
      <span class="text-sm text-gray-500">Welcome → <strong class="text-rose-600">Choose Role</strong> → Complete</span>
    </div>
  </div>
</div>

<!-- Enable Continue when a role is chosen (styling via CSS peer classes) -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const radios = document.querySelectorAll('.role-radio');
    const continueBtn = document.getElementById('continue-btn');
    function update() {
      const anyChecked = Array.from(radios).some(r => r.checked);
      continueBtn.disabled = !anyChecked;
    }
    radios.forEach(r => r.addEventListener('change', update));
    update();
  });
</script>