<% content_for :title, "Setup Complete!" %>

<div class="max-w-4xl mx-auto text-center">
  <!-- Success Animation -->
  <div class="mb-8">
    <div class="inline-flex items-center justify-center w-24 h-24 bg-gradient-to-br from-green-400 to-emerald-500 rounded-full mb-6 animate-bounce">
      <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="text-5xl font-black text-gray-900 mb-4">
      <span class="bg-gradient-to-r from-green-600 to-emerald-600 bg-clip-text text-transparent">
        All Set!
      </span>
    </h1>

    <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
      Your Ruby Buddy profile is ready! You're now part of our awesome community.
    </p>
  </div>

  <!-- Role-specific next steps -->
  <div class="bg-white rounded-2xl border-2 border-gray-100 shadow-lg p-8 mb-8">
    <% if current_user.mentee? && current_user.mentor? %>
      <!-- Both role -->
      <h2 class="text-2xl font-bold text-purple-900 mb-4">
        🤝 Welcome, Community Member!
      </h2>
      <p class="text-gray-600 mb-6">
        You can now help others as a mentor AND request mentorship for advanced topics.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <%= link_to new_profile_path,
            class: "inline-flex items-center justify-center gap-2 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-bold px-6 py-3 rounded-xl hover:from-green-600 hover:to-emerald-700 transition-all" do %>
          <span>🌟</span>
          <span>Set Up Mentor Profile</span>
        <% end %>

        <%= link_to new_mentorship_request_path,
            class: "inline-flex items-center justify-center gap-2 bg-gradient-to-r from-blue-500 to-indigo-600 text-white font-bold px-6 py-3 rounded-xl hover:from-blue-600 hover:to-indigo-700 transition-all" do %>
          <span>🎯</span>
          <span>Request Mentorship</span>
        <% end %>
      </div>

    <% elsif current_user.mentor? %>
      <!-- Mentor role -->
      <h2 class="text-2xl font-bold text-green-900 mb-4">
        🌟 Welcome, Mentor!
      </h2>
      <p class="text-gray-600 mb-6">
        Thank you for volunteering to help others! Set up your profile and start accepting mentorship requests.
      </p>

      <%= link_to new_profile_path,
          class: "inline-flex items-center gap-2 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-bold text-lg px-8 py-4 rounded-xl hover:from-green-600 hover:to-emerald-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl" do %>
        <span>🚀</span>
        <span>Create Your Mentor Profile</span>
      <% end %>

    <% elsif current_user.mentee? %>
      <!-- Mentee role -->
      <h2 class="text-2xl font-bold text-blue-900 mb-4">
        🎯 Welcome, Future Rubyist!
      </h2>
      <p class="text-gray-600 mb-6">
        Ready to accelerate your learning? Create your first mentorship request and get matched with an experienced developer.
      </p>

      <%= link_to new_mentorship_request_path,
          class: "inline-flex items-center gap-2 bg-gradient-to-r from-blue-500 to-indigo-600 text-white font-bold text-lg px-8 py-4 rounded-xl hover:from-blue-600 hover:to-indigo-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl" do %>
        <span>✨</span>
        <span>Create Mentorship Request</span>
      <% end %>
    <% end %>
  </div>

  <!-- Quick Tips -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 rounded-xl p-6">
      <div class="text-3xl mb-3">💬</div>
      <h3 class="font-bold text-blue-900 mb-2">Real-time Chat</h3>
      <p class="text-sm text-blue-700">
        Use our beautiful chat interface with typing indicators and read receipts
      </p>
    </div>

    <div class="bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-xl p-6">
      <div class="text-3xl mb-3">🤝</div>
      <h3 class="font-bold text-green-900 mb-2">Be Respectful</h3>
      <p class="text-sm text-green-700">
        Everyone here volunteers their time. Be kind, patient, and grateful
      </p>
    </div>

    <div class="bg-gradient-to-br from-purple-50 to-pink-50 border border-purple-200 rounded-xl p-6">
      <div class="text-3xl mb-3">🚀</div>
      <h3 class="font-bold text-purple-900 mb-2">Have Fun!</h3>
      <p class="text-sm text-purple-700">
        Learning and teaching Ruby should be enjoyable. Don't hesitate to ask questions
      </p>
    </div>
  </div>

  <!-- Secondary Actions -->
  <div class="flex flex-wrap justify-center gap-4">
    <%= link_to mentorship_requests_path,
        class: "inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium px-4 py-2 rounded-lg hover:bg-gray-100 transition-all" do %>
      <span>Browse Community</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    <% end %>

    <%= link_to profiles_path,
        class: "inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium px-4 py-2 rounded-lg hover:bg-gray-100 transition-all" do %>
      <span>Meet Mentors</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    <% end %>
  </div>

  <!-- Progress Indicator - Complete! -->
  <div class="mt-12">
    <div class="flex items-center justify-center space-x-2">
      <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold">✓</div>
      <div class="w-16 h-1 bg-green-500 rounded"></div>
      <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold">✓</div>
      <div class="w-16 h-1 bg-green-500 rounded"></div>
      <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold">✓</div>
    </div>
    <div class="flex justify-center mt-2">
      <span class="text-sm text-green-600 font-semibold">Welcome → Choose Role → <strong>Complete!</strong></span>
    </div>
  </div>
</div>