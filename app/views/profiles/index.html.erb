<% content_for :title, "Mentors" %>

<%= section_container do %>
  <%# Page Header %>
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-4xl font-black tracking-tight text-zinc-900">💎 Friendly Ruby Mentors</h1>
        <p class="text-zinc-700 font-medium text-lg">Every working Ruby developer has experiences to offer those following us into our community. <span class="text-rose-600 font-bold">Always free!</span> 🚀</p>
      </div>
      <% if user_signed_in? %>
        <%= button_primary "✨ Edit my profile", (current_user.profile ? edit_profile_path(current_user.profile) : new_profile_path) %>
      <% end %>
    </div>
  </div>

  <%= form_with url: profiles_path, method: :get, local: true, class: "flex gap-3" do |f| %>
    <%= f.search_field :q, value: @q, placeholder: "🔍 Search skills, name, bio...", class: "flex-1 rounded-lg border-2 border-zinc-300 focus:ring-rose-500 focus:border-rose-500 px-4 py-3 text-lg font-medium shadow-sm" %>
    <%= f.submit "🚀 Search", class: "rounded-lg bg-rose-600 text-white px-6 py-3 font-semibold hover:bg-rose-700 transition-colors shadow-lg" %>
  <% end %>

  <div id="profiles" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% if @profiles.any? %>
      <% @profiles.each do |profile| %>
        <div class="rounded-lg border-2 border-zinc-700 bg-zinc-800 p-6 shadow-xl hover:shadow-2xl transition-all">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-black text-xl text-white"><%= profile.name.presence || profile.user.email %></h3>
              <p class="text-sm text-zinc-400 font-medium">🌍 <%= profile.timezone %> <% if profile.years_experience.present? %> • ⭐ <%= profile.years_experience %> yrs<% end %></p>
            </div>
            <% if profile.mentor? %>
              <span class="inline-flex items-center rounded-full bg-rose-600 px-3 py-1 text-xs font-bold text-white shadow-lg">💎 Mentor</span>
            <% end %>
          </div>
          <p class="mt-3 text-sm text-zinc-300 line-clamp-3 font-medium"><%= profile.bio %></p>
          <% if profile.skills.present? %>
            <div class="mt-3 flex flex-wrap gap-2">
              <% profile.skills.to_s.split(',').map(&:strip).reject(&:blank?).first(12).each do |skill| %>
                <span class="inline-flex items-center rounded-full bg-rose-600 text-white text-xs px-3 py-1 shadow-md font-bold">🔥 <%= skill %></span>
              <% end %>
            </div>
          <% end %>
          <div class="mt-5 flex items-center gap-3">
            <%= link_to "👀 View", profile_path(profile), class: "inline-flex items-center rounded-lg bg-zinc-700 px-4 py-2 text-sm font-bold text-white border border-zinc-600 hover:bg-zinc-600 transition-colors shadow-sm" %>
            <% if user_signed_in? %>
              <%= link_to "🚀 Request", new_mentorship_request_path(mentorship_request: { mentor_id: profile.user_id }), class: "inline-flex items-center rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700 transition-colors shadow-lg" %>
            <% else %>
              <%= link_to "🚀 Sign up to request", new_user_registration_path, class: "inline-flex items-center rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700 transition-colors shadow-lg" %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10 text-zinc-600">No mentors found.</p>
    <% end %>
  </div>
<% end %>
