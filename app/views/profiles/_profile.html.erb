<div id="<%= dom_id profile %>" class="max-w-4xl mx-auto">
  <!-- Header Section -->
  <div class="rounded-lg border border-zinc-700 bg-zinc-800 p-8 mb-6">
    <div class="flex items-start justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">
          <%= profile.name.presence || profile.user.email %>
        </h1>
        <div class="flex items-center gap-4 text-zinc-400">
          <span class="flex items-center gap-1">
            🌍 <%= profile.timezone %>
          </span>
          <% if profile.years_experience.present? %>
            <span class="flex items-center gap-1">
              ⭐ <%= profile.years_experience %> years experience
            </span>
          <% end %>
        </div>
      </div>
      <div class="flex gap-2">
        <% if profile.mentor? %>
          <span class="inline-flex items-center rounded-full bg-rose-600 px-3 py-1 text-sm font-bold text-white">💎 Mentor</span>
        <% end %>
        <% if profile.mentee? %>
          <span class="inline-flex items-center rounded-full bg-blue-600 px-3 py-1 text-sm font-bold text-white">🎯 Mentee</span>
        <% end %>
      </div>
    </div>

    <% if profile.bio.present? %>
      <div class="mb-6">
        <h3 class="text-lg font-semibold text-rose-400 mb-2">About</h3>
        <p class="text-zinc-300 leading-relaxed"><%= profile.bio %></p>
      </div>
    <% end %>

    <% if profile.skills.present? %>
      <div class="mb-6">
        <h3 class="text-lg font-semibold text-rose-400 mb-3">Skills</h3>
        <div class="flex flex-wrap gap-2">
          <% profile.skills.to_s.split(',').map(&:strip).reject(&:blank?).each do |skill| %>
            <span class="inline-flex items-center rounded-full bg-rose-600 text-white text-sm px-3 py-1 font-medium">🔥 <%= skill %></span>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if profile.availability.present? %>
      <div class="mb-6">
        <h3 class="text-lg font-semibold text-rose-400 mb-2">Availability</h3>
        <p class="text-zinc-300"><%= profile.availability %></p>
      </div>
    <% end %>
  </div>

  <!-- Links Section -->
  <% if profile.github_url.present? || profile.x_url.present? || profile.website_url.present? %>
    <div class="rounded-lg border border-zinc-700 bg-zinc-800 p-6">
      <h3 class="text-lg font-semibold text-rose-400 mb-4">Connect</h3>
      <div class="flex flex-wrap gap-3">
        <% if profile.github_url.present? %>
          <%= link_to profile.github_url, target: "_blank", class: "inline-flex items-center gap-2 rounded-lg bg-zinc-700 px-4 py-2 text-white hover:bg-zinc-600 transition-colors border border-zinc-600" do %>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"></path>
            </svg>
            GitHub
          <% end %>
        <% end %>
        <% if profile.x_url.present? %>
          <%= link_to profile.x_url, target: "_blank", class: "inline-flex items-center gap-2 rounded-lg bg-zinc-700 px-4 py-2 text-white hover:bg-zinc-600 transition-colors border border-zinc-600" do %>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M11.4678 8.77491L17.2961 2H15.915L10.8543 7.88256L6.81232 2H2.15039L8.26263 10.8955L2.15039 18H3.53159L8.87581 11.7878L13.1444 18H17.8063L11.4675 8.77491H11.4678ZM9.57608 10.9738L8.95678 10.0881L4.02925 3.03974H6.15068L10.1273 8.72795L10.7466 9.61374L15.9156 17.0075H13.7942L9.57608 10.9742V10.9738Z"/>
            </svg>
            X (Twitter)
          <% end %>
        <% end %>
        <% if profile.website_url.present? %>
          <%= link_to profile.website_url, target: "_blank", class: "inline-flex items-center gap-2 rounded-lg bg-zinc-700 px-4 py-2 text-white hover:bg-zinc-600 transition-colors border border-zinc-600" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9m0 9c-5 0-9-4-9-9s4-9 9-9"></path>
            </svg>
            Website
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
