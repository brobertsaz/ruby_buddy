<% content_for :title, "Showing profile" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl text-zinc-900">Showing profile</h1>

  <%= render @profile %>

  <%= link_to "Edit this profile", edit_profile_path(@profile), class: "w-full sm:w-auto text-center rounded-lg px-3.5 py-2.5 bg-zinc-700 hover:bg-zinc-600 text-white inline-block font-medium border border-zinc-600" %>
  <%= link_to "Back to profiles", profiles_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-lg px-3.5 py-2.5 bg-zinc-700 hover:bg-zinc-600 text-white inline-block font-medium border border-zinc-600" %>
  <%= button_to "Destroy this profile", @profile, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-lg px-3.5 py-2.5 text-white bg-rose-600 hover:bg-rose-700 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>
