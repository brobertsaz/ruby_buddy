<% content_for :title, "Create your account" %>

<div class="mx-auto max-w-md bg-zinc-900 border border-zinc-700 rounded-xl p-8 mt-8 shadow-xl">
  <div class="text-center mb-6">
    <div class="inline-flex items-center gap-2 text-rose-600 mb-2">
      <span class="inline-block w-3 h-3 rounded-full bg-rose-500"></span>
      <span class="font-semibold text-lg">Ruby Pair</span>
    </div>
    <h1 class="text-2xl font-bold text-zinc-100">Join Our Community! <i class="fa-solid fa-champagne-glasses ml-2"></i></h1>
    <p class="text-zinc-400 mt-1">Connect with Ruby mentors or start mentoring others</p>
  </div>

  <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), class: "space-y-5", data: { turbo: true }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, "Email Address", class: form_label_classes %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: form_input_classes,
            placeholder: "your@email.com" %>
    </div>

    <div>
      <%= f.label :password, class: form_label_classes %>
      <%= f.password_field :password, autocomplete: "new-password",
            class: form_input_classes,
            placeholder: "Create a strong password" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-zinc-500 mt-1 flex items-center gap-1">
          <i class="fa-solid fa-lock mr-1"></i> Minimum <%= @minimum_password_length %> characters
        </p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm Password", class: form_label_classes %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: form_input_classes,
            placeholder: "Confirm your password" %>
    </div>

    <div class="pt-2">
      <%= f.submit raw('<i class="fa-solid fa-user-plus mr-2"></i> Create Account'), class: "w-full rounded-lg px-4 py-3 bg-rose-600 hover:bg-rose-700 text-white font-semibold transition-colors shadow-lg" %>
    </div>
  <% end %>

  <div class="mt-6 pt-6 border-t border-zinc-700 text-center text-sm text-zinc-400">
    <%= render "devise/shared/links" %>
  </div>
</div>

