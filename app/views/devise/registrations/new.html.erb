<% content_for :title, "Create your account" %>

<div class="mx-auto max-w-md bg-white/95 backdrop-blur border border-zinc-200 rounded-xl p-8 mt-8 shadow-xl">
  <div class="text-center mb-6">
    <div class="inline-flex items-center gap-2 text-rose-600 mb-2">
      <span class="inline-block w-3 h-3 rounded-full bg-rose-500"></span>
      <span class="font-semibold text-lg">Pay It Forward</span>
    </div>
    <h1 class="text-2xl font-bold text-zinc-900">Join Our Community! 🎉</h1>
    <p class="text-zinc-600 mt-1">Connect with Ruby mentors or start mentoring others</p>
  </div>

  <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), class: "space-y-5", data: { turbo: true }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, "Email Address", class: light_form_label_classes %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", 
            class: light_form_input_classes,
            placeholder: "your@email.com" %>
    </div>

    <div>
      <%= f.label :password, class: light_form_label_classes %>
      <%= f.password_field :password, autocomplete: "new-password", 
            class: light_form_input_classes,
            placeholder: "Create a strong password" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-zinc-500 mt-1 flex items-center gap-1">
          🔒 Minimum <%= @minimum_password_length %> characters
        </p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm Password", class: light_form_label_classes %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", 
            class: light_form_input_classes,
            placeholder: "Confirm your password" %>
    </div>

    <div class="pt-2">
      <%= f.submit "🎆 Create Account", class: "w-full rounded-lg px-4 py-3 bg-rose-600 hover:bg-rose-700 text-white font-semibold transition-colors shadow-lg" %>
    </div>
  <% end %>

  <div class="mt-6 pt-6 border-t border-zinc-200 text-center text-sm text-zinc-600">
    <%= render "devise/shared/links" %>
  </div>
</div>

