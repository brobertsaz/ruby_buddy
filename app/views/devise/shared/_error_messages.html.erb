<% if resource && resource.errors.any? %>
  <div class="mb-4 rounded border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
    <h2 class="font-semibold mb-1"><%= pluralize(resource.errors.count, "error") %> prevented this from saving:</h2>
    <ul class="list-disc ml-5">
      <% resource.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

