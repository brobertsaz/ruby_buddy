<% content_for :title, "Sign in" %>

<div class="mx-auto max-w-md bg-zinc-900 border border-zinc-700 rounded-xl p-8 mt-8 shadow-xl">
  <div class="text-center mb-6">
    <div class="inline-flex items-center gap-2 text-rose-600 mb-2">
      <span class="inline-block w-3 h-3 rounded-full bg-rose-500"></span>
      <span class="font-semibold text-lg">Ruby Pair</span>
    </div>
    <h1 class="text-2xl font-bold text-zinc-100">Welcome back! 👋</h1>
    <p class="text-zinc-400 mt-1">Sign in to continue your mentorship journey</p>
  </div>

  <%= form_with(scope: resource_name, url: session_path(resource_name), class: "space-y-5", data: { turbo: true }) do |f| %>
    <div>
      <%= f.label :email, "Email Address", class: form_label_classes %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: form_input_classes,
            placeholder: "your@email.com" %>
    </div>

    <div>
      <%= f.label :password, class: form_label_classes %>
      <%= f.password_field :password, autocomplete: "current-password",
            class: form_input_classes,
            placeholder: "Enter your password" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "h-4 w-4 text-rose-600 border-zinc-700 rounded focus:ring-rose-500" %>
        <%= f.label :remember_me, "Keep me signed in", class: "text-sm text-zinc-400" %>
      </div>
    <% end %>

    <div class="pt-2">
      <%= f.submit "Sign in →", class: "w-full rounded-lg px-4 py-3 bg-rose-600 hover:bg-rose-700 text-white font-semibold transition-colors shadow-lg" %>
    </div>
  <% end %>

  <div class="mt-6 pt-6 border-t border-zinc-700 text-center text-sm text-zinc-400">
    <%= render "devise/shared/links" %>
  </div>
</div>

