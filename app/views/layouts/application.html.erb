<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pay It Forward - Free Ruby Mentorship" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gradient-to-br from-zinc-50 to-zinc-100 text-zinc-900 min-h-screen">
    <%# Include shared UI components %>
    <%= render 'shared/ui_components' %>
    <header class="fixed top-0 inset-x-0 z-50 backdrop-blur bg-zinc-900/95 border-b border-zinc-700">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-semibold text-rose-400 hover:text-rose-300 transition-colors">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-rose-500"></span>
          Pay It Forward
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <%= link_to "Mentors", profiles_path, class: "text-zinc-300 hover:text-rose-400 transition-colors" %>
          <% if user_signed_in? %>
            <%= link_to "My Requests", mentorship_requests_path, class: "text-zinc-300 hover:text-rose-400 transition-colors" %>
            <%= link_to "Dashboard", edit_profile_path(current_user.profile || Profile.new), class: "text-zinc-300 hover:text-rose-400 transition-colors" rescue nil %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-zinc-300 hover:text-rose-400 transition-colors border-0 bg-transparent p-0" %>
          <% else %>
            <%= link_to "Browse Requests", mentorship_requests_path, class: "text-zinc-300 hover:text-rose-400 transition-colors" %>
            <%= link_to "Sign in", new_user_session_path, class: "text-zinc-300 hover:text-rose-400 transition-colors" %>
            <%= link_to "Sign up", new_user_registration_path, class: "inline-flex items-center gap-1.5 rounded-lg bg-rose-600 px-3 py-1.5 text-white hover:bg-rose-700 transition-colors shadow-md" %>
          <% end %>
        </nav>
      </div>
    </header>

    <%# Flash messages container with consistent styling %>
    <div class="max-w-6xl mx-auto px-4 pt-24 pb-2">
      <% if notice %>
        <div class="mb-6 rounded-xl bg-gradient-to-r from-green-50 to-emerald-50 text-green-800 border-2 border-green-200 px-4 py-3 shadow-sm backdrop-blur">
          <div class="flex items-center gap-2">
            <span class="text-green-600">🎉</span>
            <span class="font-medium"><%= notice %></span>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-6 rounded-xl bg-gradient-to-r from-red-50 to-rose-50 text-red-800 border-2 border-red-200 px-4 py-3 shadow-sm backdrop-blur">
          <div class="flex items-center gap-2">
            <span class="text-red-600">⚠️</span>
            <span class="font-medium"><%= alert %></span>
          </div>
        </div>
      <% end %>
    </div>

    <main class="max-w-6xl mx-auto px-4 pb-12">
      <%= yield %>
    </main>
  </body>
</html>
