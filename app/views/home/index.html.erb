


<section class="relative z-10 grid lg:grid-cols-2 gap-10 items-center">
  <%# Floating tech badges - positioned at section level %>
  <div class="absolute top-0 right-0 flex gap-3 z-20">
    <div class="glass-item rounded-2xl p-3 hover-red-glow smooth-transition hover:scale-110" title="Built with Ruby">
      <%= image_tag "ruby-logo.svg", alt: "Ruby", class: "w-10 h-10" %>
    </div>
    <div class="glass-item rounded-2xl p-3 hover-red-glow smooth-transition hover:scale-110" title="Powered by Rails">
      <%= image_tag "rails-logo.svg", alt: "Rails", class: "w-10 h-10" %>
    </div>
  </div>

  <div>
    <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-zinc-100">
      Mentor the next Rubyist.
      <br>
      <span class="text-ruby-gradient mt-8">Or find yours!</span>
    </h1>
    <p class="mt-6 text-zinc-300 text-xl font-medium">
      <span class="text-rose-400 font-bold">Free mentorship</span> connecting early career developers with experienced Rubyists.
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <%= link_to raw('<i class="fa-solid fa-rocket mr-2"></i> Find a mentor'), profiles_path, class: "inline-flex items-center gap-2 rounded-2xl bg-gradient-to-r from-red-500 to-red-600 px-6 py-3 text-white font-bold text-lg shadow-xl hover:from-red-600 hover:to-red-700 transform hover:scale-105 transition-all ruby-sparkle btn-pulse-glow" %>
      <%= link_to raw('<i class="fa-solid fa-clipboard-list mr-2"></i> Request mentorship'), new_mentorship_request_path, class: "inline-flex items-center gap-2 rounded-2xl bg-zinc-900 px-6 py-3 text-rose-300 font-bold text-lg ring-1 ring-rose-500/30 hover:bg-zinc-800 hover:ring-rose-400/40 transform hover:scale-105 transition-all shadow-lg hover-red-glow" %>
    </div>
  </div>
  <div class="relative">

    <div class="absolute -inset-8 -z-10 bg-gradient-to-tr from-rose-500/10 via-rose-400/5 to-transparent rounded-3xl blur-3xl opacity-70"></div>
    <div class="rounded-3xl p-8 glass-card">
      <div class="grid grid-cols-2 gap-6">
        <div class="rounded-2xl p-5 glass-item">
          <p class="text-sm text-rose-400 font-medium">We are nice</p>
          <p class="font-black text-white text-lg">Free mentorship</p>
        </div>
        <div class="rounded-2xl p-5 glass-item">
          <p class="text-sm text-rose-400 font-medium">Help wanted</p>
          <p class="font-black text-white text-lg">Anyone can mentor</p>
        </div>
        <div class="rounded-2xl p-5 glass-item">
          <p class="text-sm text-rose-400 font-medium">Built with</p>
          <p class="font-black text-white text-lg">Ruby on Rails</p>
        </div>
        <div class="rounded-2xl p-5 glass-item">
          <p class="text-sm text-rose-400 font-medium">Connect</p>
          <p class="font-black text-white text-lg">Real conversations</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="relative z-10 mt-16 grid lg:grid-cols-2 gap-12 items-center">
  <div class="rounded-3xl p-8 glass-card">
    <h2 class="text-3xl font-black text-rose-400 mb-4">We are nice</h2>
    <h3 class="text-xl font-bold text-white mb-3">Free mentorship. Always.</h3>
    <p class="text-zinc-300 font-medium leading-relaxed">
      If you're starting out or in your first year of a programming career, we'll pair you up with an existing Rubyist.
      We match you with someone with the experience you're looking for and you can ask whatever you like.
      <span class="text-rose-400 font-bold">No cost, no catch, just community.</span>
    </p>
    <div class="mt-6">
      <%= link_to raw('<i class="fa-solid fa-rocket mr-2"></i> Find your mentor'), profiles_path, class: "inline-flex items-center gap-2 rounded-xl bg-rose-600 px-4 py-2 text-white font-bold hover:bg-rose-700 transition-colors shadow-lg" %>
    </div>
  </div>

  <div class="rounded-3xl p-8 glass-card">
    <h2 class="text-3xl font-black text-rose-400 mb-4">Help wanted</h2>
    <h3 class="text-xl font-bold text-white mb-3">Anyone can be a mentor.</h3>
    <p class="text-zinc-300 font-medium leading-relaxed">
      Every working Ruby developer has experiences to offer to those following us into our community.
      You only need a year of programming before you can give back.
      <span class="text-rose-400 font-bold">Share your journey, help someone else's.</span>
    </p>
    <div class="mt-6">
      <%= link_to raw('<i class="fa-solid fa-user-plus mr-2"></i> Become a mentor'), new_profile_path, class: "inline-flex items-center gap-2 rounded-xl bg-zinc-700 px-4 py-2 text-white font-bold border border-zinc-600 hover:bg-zinc-600 transition-colors shadow-lg" %>
    </div>
  </div>
</section>
